{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true
  },
  "include": [
    "server/**/*.js",
    "ui/**/*.js",
    "ui/types.d.ts",
    "cli/**/*.js",
    "electron/**/*.cjs",
    "scripts/**/*.js",
    "scripts/**/*.cjs",
    "scripts/**/*.mjs",
    "mcp-server.mjs",
    "mcp-http-server.mjs",
    "mcp-tools.mjs",
    "mcp-oauth.mjs",
    "mcpb/context-engine/server/**/*.mjs"
  ],
  "exclude": ["node_modules", "data", "skills", "dist", "out", ".tmp"]
}
